{
  "name": "pangraphic",
  "private": true,
  "version": "1.0.0-alabaster",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "npm run build:mcp && vite build",
    "build:mcp": "cp public/static-mcp.json mcp.json",
